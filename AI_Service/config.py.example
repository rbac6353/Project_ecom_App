# Configuration Example for AI Service
# Copy this file to config.py and update with your actual values

# Database Configuration (should match Backend/.env)
DB_USERNAME = 'root'
DB_PASSWORD = 'your_password_here'  # Change this!
DB_HOST = 'localhost'
DB_PORT = 3306
DB_DATABASE = 'ecom1'  # or 'gtxshop_db' depending on your setup

# NestJS Base URL (for accessing images)
NESTJS_BASE_URL = 'http://localhost:3000'

